@article{wang2020synthetic,
  abbr={NAR},
  title={Synthetic promoter design in {{Escherichia}} coli based on a deep generative network},
  author={Wang*, Ye and Wang*, Haochen and Wei, Lei and Li, Sichao and Liu, Lingxue and Wang†, Xiaowo},
  journal={Nucleic Acids Research},
  volume={48},
  number={12},
  pages={6403--6412},
  year={2020},
  doi={10.1093/nar/gkaa325},
  selected={true},
  preview={nar.png},
  award={Cover Paper & Breakthrough Article, Nucleic Acids Research},
  additional_info={<br>*Equal contribution. †Corresponding author.},
  abstract={My research during PhD training focused on developing AI-based generative algorithms and optimization methods for de novo promoter sequence design. Understanding the complex encoding syntax in the genome and using it to build synthetic circuits will accelerate synthetic biology parts discovery and hopefully bring new drug candidates to the clinic. This approach achieved high success rates in in vivo experimental validations, offering valuable insights into synthetic element design and highlighting the potential of deep learning to explore the vast sequence space of synthetic biology.}
}
