@article{xu2024reference,
  abbr={Genome Res.},
  title={Reference-informed prediction of alternative splicing and splicing-altering mutations from sequences},
  author={Xu*, Chencheng and Bao*, Suying and Wang*, Ye and Li*, Wenxing and Chen*, Hao and Shen*, Yufeng and Jiang†, Tao and Zhang†, Chaolin},
  journal={Genome Research},
  volume={34},
  number={7},
  pages={1052--1065},
  year={2024},
  doi={10.1101/gr.279044.124},
  selected={true},
  preview={genome-research.png},
  additional_info={<br>*Equal contribution. †Corresponding authors.},
  abstract={We introduced a reference-informed computational framework that systematically links sequence context to splice-site usage across human tissues, enabling quantitative prediction of splicing-altering mutations. This platform supports functional interpretation of genetic variants in the context of human disease, providing mechanistic insight into how noncoding and coding variants disrupt RNA processing. By transforming large-scale transcriptomic data into predictive models of splicing regulation, our work facilitates clinically meaningful variant prioritization, improves the interpretation of patient genomic data, and informs the rational design of RNA-targeted therapeutic strategies. This framework bridges fundamental RNA biology with translational medicine, creating a scalable foundation for precision diagnostics and RNA-based therapeutic development.}
}

@article{zhang2025systematic,
  abbr={Nat. Commun.},
  title={Systematic representation and optimization enable the inverse design of cross-species regulatory sequences in bacteria},
  author={Zhang*, Pengcheng and Du*, Qixiu and Wang*, Ye and Wei, Lei and Wang†, Xiaowo},
  journal={Nature Communications},
  volume={16},
  number={1},
  pages={1763},
  year={2025},
  doi={10.1038/s41467-025-57031-1},
  selected={true},
  preview={nat-commun.png},
  award={Featured Article — Editors' Highlights in Biotechnology and Methods, Nature Communications},
  additional_info={<br>*Equal contribution. †Corresponding author.},
  abstract={Long-tail distribution is a common problem in genetic-elements inverse design and engineering tasks based on generative AI. The combination of massive quantification-screen experiments and exploration procedures guided by generative AI efficiently fills in the sequence-activity landscape and significantly improves the performance of predictive and generative models for inverse design. The strategy of generative AI-guided high-throughput exploration shows potential to overcome data scarcity, a common problem in inverse design and engineering tasks. DeepCROSS offers the potential to go beyond designing bacterial regulatory sequences and be used for mammalian regulatory sequence design, taking a step toward constructing complex circuits using generative AI for the synthetic biology community.}
}

